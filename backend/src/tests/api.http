POST http://localhost:3000/api/auth/login
Content-Type: application/json

{
  "identificador": "30",
  "senha": "senhaAtendente123"
}

### 3. O Teste de Bloqueio: Atendente tentando ABRIR uma Conta
# Copie o token que foi gerado no Passo 2 e cole aqui.
# O resultado OBRIGATÓRIO deve ser o Erro 403 Forbidden.
POST http://localhost:3000/api/contas
Content-Type: application/json
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZGVudGlmaWNhZG9yIjozMCwiY2FyZ28iOiJhdGVuZGVudGUiLCJpYXQiOjE3ODIyNjAzNTgsImV4cCI6MTc4MjI4OTE1OH0.hvP1QMlQ0QbjQ4wBdmzaPiHolY2jx1YjiZ7JaNzH0a4

{
  "num_ag": 5,
  "matricula_gerente": 1,
  "saldo": 100.00,
  "senha": "senhaInvasao456",
  "tipo_conta": "conta_corrente"
}

